{
    "custom/arch": {
        "format": "¾░úç",
        "tooltip": true,
        "tooltip-format": "LEMO"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "hyprland/window":{
        "format": " ¯¡┐  {}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "max-volume": 150,
        "scroll-step": 5,
        "format-muted": "´Ü®",
        "format-icons": {
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },


    "bluetooth": {
        "format": "´èö",
        "tooltip": true,
        "tooltip-format": "{status}",
        "on-click": "~/.config/waybar/scripts/bluetooth.sh"
    },

    "network": {
        "format-wifi": "´ç½ {essid}" ,
        "tooltip": true,
        "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%\nSpeed: {bandwidthDownBits} Ôåô / {bandwidthUpBits} Ôåæ",
        "format-ethernet": "´×û",
        "format-disconnected": "ÔÜá",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/network.sh"
    },

    "custom/sysmon": {
        "format": "¾░¬½ ",
        "tooltip": true,
        "tooltip-format": "{}",
        "exec": "~/.config/waybar/scripts/sysmon.sh",
        "interval": 2
    },

    "cpu": {
        "format": "CPU {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "RAM {percentage}%",
        "interval": 2,
        "tooltip": false
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits | awk '{print $1 \"%\"}'",
        "interval": 2,
        "format": "GPU {}",
        "tooltip": false
    },

    "disk": {
        "interval": 30,
        "format": "DISK {free} / {total}",
        "tooltip-format": "{used} used out of {total} on {path}",
        "path": "/"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´âº {capacity}%",
        "format-plugged": "´çª {capacity}%",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "on-click": "~/.config/waybar/scripts/power-profiles.sh"
    },

    "clock": {
        "format": "´Çù {:%I:%M %p   ´ü│ %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "custom/power": {
        "format": "´Çæ",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/powermenu.sh"
    },

    "custom/gaming": {
        "exec": "~/.config/waybar/scripts/gamemode_check.sh",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "on-click": "~/.config/hypr/scripts/gamemode.sh",
        "tooltip": true
    }
}
