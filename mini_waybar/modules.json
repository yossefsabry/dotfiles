{
    "custom/arch": {
        "format": "󰣇",
        "tooltip": true,
        "tooltip-format": "Made with 𖹭 \n ~shivam"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "hyprland/window":{
        "format": "   {}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "max-volume": 150,
        "scroll-step": 5,
        "format-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },


    "bluetooth": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "{status}",
        "on-click": "~/.config/waybar/scripts/bluetooth.sh"
    },

    "network": {
        "format-wifi": " {essid}" ,
        "tooltip": true,
        "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%\nSpeed: {bandwidthDownBits} ↓ / {bandwidthUpBits} ↑",
        "format-ethernet": "",
        "format-disconnected": "⚠",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/network.sh"
    },

    "custom/sysmon": {
        "format": "󰪫 ",
        "tooltip": true,
        "tooltip-format": "{}",
        "exec": "~/.config/waybar/scripts/sysmon.sh",
        "interval": 2
    },



    "cpu": {
        "format": "Cpu: {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "Ram: {percentage}%",
        "interval": 2,
        "tooltip": false
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits | awk '{print \"Gpu: \" $1 \"%\"}'",
        "interval": 2,
        "format": "{}",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        

        "on-click": "~/.config/waybar/scripts/power-profiles.sh"
    },

    "clock": {
        "format": " {:%I:%M %p    %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },


    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/powermenu.sh"
    }
}
