# --- Sioyek General Preferences ---

# Start in dark mode automatically (like your Zathura recolor "true")
startup_commands toggle_dark_mode

# True Dark Mode Colors (Background & Foreground)
# Format: R G B (0.0 to 1.0)
dark_mode_background_color    0.05 0.05 0.05
dark_mode_contrast            0.8

# UI Colors
status_bar_color              0.10 0.10 0.10
status_bar_text_color         0.90 0.90 0.90

# Search Highlighting (Yellowish)
search_highlight_color        1.0 1.0 0.0

# Link Highlighting
link_highlight_color          0.0 0.5 1.0

# How much to zoom on each step
zoom_inc                      1.2
