# --- Sioyek Keybindings ---

# Matching your Zathura zoom logic
# C-j for zoom out, C-k for zoom in
zoom_out             <C-j>
zoom_in              <C-k>

# Matching your Zathura Page Navigation (S-j and S-k)
next_page            J
previous_page        K

# Toggle Dark Mode (Replacing 'i' in Zathura)
toggle_dark_mode     i

# Reload document
reload               r

# Fullscreen (Matching your 'f' map)
toggle_fullscreen    f

# Smooth scrolling with jk
screen_down          j
screen_up            k

# Horizontal movement (Arrow Left and Right replacement)
move_left            l
move_right           h

# Increase horizontal scroll speed (default is usually 0.1 or 0.2)
horizontal_move_amount 0.5

# Open document
open_document        o
