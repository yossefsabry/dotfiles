#!/usr/bin/bash

# Function to format a markdown note
format_note() {
  local file_path="$1"
  
  if [ -z "$file_path" ]; then
    echo "Usage: format_note <path_to_markdown_file>"
    return 1
  fi

  if [ ! -f "$file_path" ]; then
    echo "Error: File $file_path not found"
    return 1
  fi

  # Get the absolute path
  local abs_path=$(realpath "$file_path")
  local name=$(basename "$abs_path" .md)
  local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
  
  # Calculate the relative path from ~/notes/ if applicable
  local relative_path=""
  if [[ "$abs_path" == "$HOME/notes/"* ]]; then
    relative_path=${abs_path#$HOME/notes/}
  else
    relative_path="$name.md"
  fi
  local folder=$(dirname "$relative_path")

  # Use Python for heavy lifting: formatting, wrapping, and cleaning
  # Passing variables as arguments to avoid shell expansion issues
  python3 - "$abs_path" "$name" "$folder" "$timestamp" <<'PYEOF'
import sys
import re
import textwrap

file_path = sys.argv[1]
name = sys.argv[2]
folder = sys.argv[3]
timestamp = sys.argv[4]

with open(file_path, 'r') as f:
    content = f.read()

# 1. Remove empty python blocks
content = re.sub(r'```python\s*```', '', content)
content = re.sub(r'```python\n\s*\n```', '', content)

# 2. Check for Header, if not there, add it
header_pattern = r'^---[\s\S]*?dg-publish[\s\S]*?---[\s\S]*?---'
if not re.search(header_pattern, content):
    header = f"""---
dg-publish: true
dg-home: false
---
---

"{file_path}"
># path: {folder}/{name}.md

```text
- **fileName**: {name}
- **Created on**: {timestamp}
```

"""
    content = header + content.strip()

# 3. Clean up whitespace
content = re.sub(r'\n{3,}', '\n\n', content)

# 4. Wrap text (max 70 chars), skipping blocks/headers
lines = content.split('\n')
formatted_lines = []
in_code_block = False
paragraph = []

def flush_paragraph():
    if paragraph:
        text = ' '.join(paragraph)
        wrapped = textwrap.wrap(text, width=70, break_long_words=False, replace_whitespace=False)
        formatted_lines.extend(wrapped)
        paragraph.clear()

for line in lines:
    if line.startswith('```'):
        flush_paragraph()
        in_code_block = not in_code_block
        formatted_lines.append(line)
    elif in_code_block:
        formatted_lines.append(line)
    elif line.strip() == '':
        flush_paragraph()
        formatted_lines.append('')
    elif line.startswith('#') or line.startswith('-') or line.startswith('*') or line.startswith('>') or line.startswith('**'):
        flush_paragraph()
        formatted_lines.append(line)
    else:
        paragraph.append(line.strip())
flush_paragraph()

content = '\n'.join(formatted_lines).strip()

# 5. Ensure Footer
if "**before**:[[" not in content:
    content += "\n\n**before**:[[]]\n**continue**:[[]]"

with open(file_path, 'w') as f:
    f.write(content + '\n')
PYEOF

  echo "Successfully formatted: $file_path"
}

# Run the function with arguments
format_note "$@"
