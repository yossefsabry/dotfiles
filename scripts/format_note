#!/usr/bin/bash

# Function to format a markdown note
format_note() {
  local file_path="$1"
  local ref_tag="$2"
  
  if [ -z "$file_path" ]; then
    echo "Usage: format_note <path_to_markdown_file> [reference_tag]"
    return 1
  fi

  if [ ! -f "$file_path" ]; then
    echo "Error: File $file_path not found"
    return 1
  fi

  # Get the absolute path
  local abs_path=$(realpath "$file_path")
  local name=$(basename "$abs_path" .md)
  local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
  
  # Calculate the relative path from ~/notes/ if applicable
  local relative_path=""
  if [[ "$abs_path" == "$HOME/notes/"* ]]; then
    relative_path=${abs_path#$HOME/notes/}
  else
    relative_path="$name.md"
  fi
  local folder=$(dirname "$relative_path")

  local before_link=""
  local is_sequence=false
  if [ -n "$ref_tag" ]; then
    is_sequence=true
    local tag_file="$HOME/notes/tags/$ref_tag"
    if [[ "$tag_file" != *.md ]]; then tag_file="$tag_file.md"; fi
    
    if [ ! -f "$tag_file" ]; then
        if [ -f "$HOME/notes/$ref_tag" ]; then
            tag_file="$HOME/notes/$ref_tag"
        elif [ -f "$ref_tag" ]; then
            tag_file=$(realpath "$ref_tag")
        fi
    fi

    if [ -f "$tag_file" ]; then
        # Use python to find the last link that IS NOT the current file
        local prev_note_abs=$(python3 - "$tag_file" "$abs_path" <<'PYEOF'
import sys
import os
import re

tag_file = sys.argv[1]
curr_abs = sys.argv[2]
tag_dir = os.path.dirname(tag_file)

last_valid_abs = ""
try:
    with open(tag_file, 'r') as f:
        for line in f:
            match = re.search(r'\[\[(.*?)\]\]', line)
            if match:
                link = match.group(1)
                abs_p = os.path.abspath(os.path.join(tag_dir, link))
                if abs_p != curr_abs:
                    last_valid_abs = abs_p
    print(last_valid_abs)
except:
    pass
PYEOF
)
        
        if [ -n "$prev_note_abs" ] && [ -f "$prev_note_abs" ]; then
            # Calculate relpath for 'before' link in current note
            before_link=$(python3 -c "import os, sys; rel = os.path.relpath(sys.argv[1], sys.argv[2]); print('./' + rel if not rel.startswith('.') else rel)" "$prev_note_abs" "$(dirname "$abs_path")")
            
            # Update the 'continue' link in the previous note
            local rel_from_prev_to_curr=$(python3 -c "import os, sys; rel = os.path.relpath(sys.argv[1], sys.argv[2]); print('./' + rel if not rel.startswith('.') else rel)" "$abs_path" "$(dirname "$prev_note_abs")")
            python3 - "$prev_note_abs" "$rel_from_prev_to_curr" <<'PYEOF'
import sys
import re
target_file = sys.argv[1]
new_link = sys.argv[2]
try:
    with open(target_file, 'r') as f:
        content = f.read()
    # Flexible regex to handle various formats of continue: [[]]
    pattern = r'(\**continue\**\s*:\s*)\[\[\]\]'
    if re.search(pattern, content, re.IGNORECASE):
        updated = re.sub(pattern, rf'\1[[{new_link}]]', content, flags=re.IGNORECASE)
        with open(target_file, 'w') as f:
            f.write(updated)
except Exception as e:
    pass
PYEOF
        fi
        
        # Add current note to tag file if it's not the last one
        local last_in_tag=$(grep '\[\[.*\]\]' "$tag_file" | tail -n 1)
        local rel_to_tag=$(python3 -c "import os, sys; rel = os.path.relpath(sys.argv[1], sys.argv[2]); print('./' + rel if not rel.startswith('.') else rel)" "$abs_path" "$(dirname "$tag_file")")
        if [[ "$last_in_tag" != *"[[$rel_to_tag]]"* ]]; then
            echo "- [[$rel_to_tag]]" >> "$tag_file"
        fi
    fi
  fi

  # Use Python for formatting the current note
  python3 - "$abs_path" "$name" "$folder" "$timestamp" "$before_link" "$is_sequence" <<'PYEOF'
import sys
import re
import textwrap

file_path = sys.argv[1]
name = sys.argv[2]
folder = sys.argv[3]
timestamp = sys.argv[4]
before_link = sys.argv[5] if len(sys.argv) > 5 else ""
is_sequence = (sys.argv[6] == "true") if len(sys.argv) > 6 else False

with open(file_path, 'r') as f:
    content = f.read()

# 1. Extract and Normalize YAML
yaml_block = "---\ndg-publish: true\ndg-home: false\n---\n"
match_yaml = re.search(r'^---\s*\n(.*?)\n---\s*\n', content, re.DOTALL)
if match_yaml:
    yaml_content = match_yaml.group(1)
    yaml_content = re.sub(r'dg-publish:\s*(true|false)\s+dg-home:\s*(true|false)', r'dg-publish: \1\ndg-home: \2', yaml_content)
    lines = yaml_content.split('\n')
    cleaned = []
    for l in lines:
        if ':' in l:
            k, v = l.split(':', 1)
            cleaned.append(f"{k.strip()}: {v.strip()}")
    if cleaned:
        yaml_block = "---\n" + "\n".join(cleaned) + "\n---\n"
    content = content[match_yaml.end():].strip()
else:
    content = content.strip()

# 2. Remove existing metadata and footer links
content = re.sub(r'^\s*".*?"\s*\n># path:.*?\n\n```text\n.*?\n```', '', content, flags=re.DOTALL | re.MULTILINE).strip()
content = re.sub(r'\n\n-?\s*\**before\**\s*:\s*\[\[.*?\]\]\n-?\s*\**continue\**\s*:\s*\[\[.*?\]\]$', '', content, flags=re.DOTALL | re.IGNORECASE).strip()

# 3. Construct Top Metadata
top_metadata = f'"{file_path}"\n># path: {folder}/{name}.md\n\n```text\n'
top_metadata += f'- **fileName**: {name}\n'
top_metadata += f'- **Created on**: {timestamp}\n'
top_metadata += '```\n'

# 4. Format content
lines = content.split('\n')
formatted_lines = []
in_code_block = False
paragraph = []

def flush_paragraph():
    if paragraph:
        text = ' '.join(paragraph)
        wrapped = textwrap.wrap(text, width=70, break_long_words=False, replace_whitespace=False)
        formatted_lines.extend(wrapped)
        paragraph.clear()

for line in lines:
    if line.startswith('```'):
        flush_paragraph()
        in_code_block = not in_code_block
        formatted_lines.append(line)
    elif in_code_block:
        formatted_lines.append(line)
    elif line.strip() == '':
        flush_paragraph()
        formatted_lines.append('')
    elif line.startswith('#') or line.startswith('-') or line.startswith('*') or line.startswith('>') or line.startswith('**'):
        flush_paragraph()
        formatted_lines.append(line)
    else:
        paragraph.append(line.strip())
flush_paragraph()

formatted_content = '\n'.join(formatted_lines).strip()

# 5. Construct Footer Links
footer_links = ""
if is_sequence:
    footer_links = f'\n\n- **before**: [[{before_link}]]\n- **continue**: [[]]'

# 6. Final Assembly
final_output = yaml_block + "\n" + top_metadata + "\n" + formatted_content + footer_links

with open(file_path, 'w') as f:
    f.write(final_output.strip() + '\n')
PYEOF

  echo "Successfully formatted: $file_path"
}

# Run the function with arguments
format_note "$@"
